# =============================================================================
# Smooth Concrete Calculator — environment variables
# =============================================================================
#
# Two scopes:
#   1. Server-only (consumed by /api/submit) — NEVER prefix with VITE_
#   2. Browser-exposed (build-time inlined by Vite)   — must start with VITE_
#
# Copy to .env.local for local dev. Configure in Vercel project settings for
# Production, Preview, and Development scopes (see DEPLOYMENT_NOTES.md).
# =============================================================================

# --- Server-only -------------------------------------------------------------
# Resend API key (https://resend.com/api-keys). Server-side only.
RESEND_API_KEY=

# Where Luke receives inquiry emails. Server-side only.
INQUIRY_RECIPIENT_EMAIL=lukeshah100@gmail.com

# Outgoing sender. For v1 ship, use the Resend sandbox sender below.
# Swap to inquiries@smoothconcrete.com.au once Resend domain verification
# is complete (see DEPLOYMENT_NOTES.md — Resend cutover).
SENDER_EMAIL=onboarding@resend.dev

# Vercel Blob token — required for plans + photo upload to work. Auto-
# injected by Vercel once you enable Blob storage on the project (see
# DEPLOYMENT_NOTES.md — Blob storage). Pull locally with `vercel env pull`.
BLOB_READ_WRITE_TOKEN=

# --- Browser-exposed ---------------------------------------------------------
# HUM partner referral URL. TODO: replace with Luke's confirmed Monday URL.
# DO NOT ship to production with the placeholder below.
VITE_HUM_PORTAL_URL=https://hum.com.au/apply?ref=smoothconcrete
