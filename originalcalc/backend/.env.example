# Smooth Concrete Calculator - SMTP Configuration Template
# Copy this to .env and fill in your actual credentials

# Outlook SMTP Settings
SMTP_SERVER=smtp.outlook.com
SMTP_PORT=587
SMTP_USER=your-outlook-email@outlook.com
SMTP_PASSWORD=your-app-specific-password

# Note: For Outlook, generate an app-specific password (not your regular password):
# https://support.microsoft.com/en-us/account-billing/using-app-passwords-with-your-microsoft-account-16b08339-bfd2-c953-07f6-4fbfb7c1f914

# Optional: Override sender email (default: from pricing.yaml)
# SENDER_EMAIL=calculator@smoothconcrete.com.au

# Optional: Override recipient email (default: from pricing.yaml)
# RECIPIENT_EMAIL=luke@smoothconcrete.com.au
