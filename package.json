{
  "name": "smooth-concrete-calculator",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Smooth Concrete driveway calculator — premium rebuild. Static SPA + one serverless function on Vercel.",
  "scripts": {
    "dev": "vite",
    "dev:vercel": "vercel dev",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 5173",
